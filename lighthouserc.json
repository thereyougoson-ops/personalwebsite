{
  "//": "Lighthouse-CI budgets. Serves ./dist directly. Assertions start as 'warn' so the first runs",
  "//2": "report real numbers without blocking; ratchet the ones you care about to 'error' once tuned.",
  "ci": {
    "collect": {
      "staticDistDir": "./dist",
      "url": ["http://localhost/index.html"],
      "numberOfRuns": 1,
      "settings": { "preset": "desktop" }
    },
    "assert": {
      "assertions": {
        "categories:performance": ["warn", { "minScore": 0.9 }],
        "categories:accessibility": ["warn", { "minScore": 1.0 }],
        "categories:best-practices": ["warn", { "minScore": 0.95 }],
        "categories:seo": ["warn", { "minScore": 0.95 }],
        "total-byte-weight": ["warn", { "maxNumericValue": 1500000 }],
        "unused-javascript": "off",
        "uses-long-cache-ttl": "off"
      }
    },
    "upload": { "target": "temporary-public-storage" }
  }
}
